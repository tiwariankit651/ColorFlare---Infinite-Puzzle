rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    function isValidScore(incoming, existing) {
      // 1. Max stars per level is 3
      let maxStars = incoming.currentLevel * 3;
      
      // 2. Score can only increase, never decrease
      let scoreNotDecreased = existing == null || (
        incoming.totalStars >= existing.totalStars && 
        incoming.currentLevel >= existing.currentLevel &&
        incoming.dailyChallenges >= existing.dailyChallenges
      );
      
      // 3. Level number can only increase by at most 1 at a time
      let levelNotJumped = existing == null || (
        incoming.currentLevel <= existing.currentLevel + 1
      );
      
      // 4. Timestamp validation: minimum 10 seconds between level completions
      let solveTimeValid = existing == null || 
        !(incoming.currentLevel > existing.currentLevel || incoming.totalStars > existing.totalStars) || (
        request.time.toMillis() - existing.updatedAt.toMillis() >= 10000
      );
      
      // 5. Username/avatar changes limited to once per hour
      let profileNotSpammed = existing == null || 
        (incoming.username == existing.username && incoming.avatarEmoji == existing.avatarEmoji) || 
        existing.lastProfileUpdate == null || (
        request.time.toMillis() - existing.lastProfileUpdate.toMillis() >= 3600000
      );
      
      return incoming.totalStars <= maxStars && 
             scoreNotDecreased && 
             levelNotJumped && 
             solveTimeValid && 
             profileNotSpammed;
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    match /leaderboard/{userId} {
      allow read: if true;
      allow create: if isOwner(userId) && isValidScore(request.resource.data, null);
      allow update: if isOwner(userId) && isValidScore(request.resource.data, resource.data);
    }

    match /leaderboard_daily_{dailyKey}/{userId} {
      allow read: if true;
      allow create: if isOwner(userId) && isValidScore(request.resource.data, null);
      allow update: if isOwner(userId) && isValidScore(request.resource.data, resource.data);
    }

    match /leaderboard_weekly_{weeklyKey}/{userId} {
      allow read: if true;
      allow create: if isOwner(userId) && isValidScore(request.resource.data, null);
      allow update: if isOwner(userId) && isValidScore(request.resource.data, resource.data);
    }

    match /leaderboard_tournament_{weeklyKey}/{userId} {
      allow read: if true;
      allow create, update: if isOwner(userId);
    }
  }
}
